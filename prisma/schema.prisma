generator client {
  provider   = "prisma-client-js"
  engineType = "library"  
}

datasource db {
  provider = "postgresql"
 // url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  password  String
  name      String
  scores    GameScore[]
  createdAt DateTime    @default(now())
}

model GameScore {
  id         String   @id @default(uuid())
  gameType   String   // 'addition', 'subtraction', 'multiplication'
  score      Int
  difficulty String   // 'easy', 'medium', 'hard'
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  createdAt  DateTime @default(now())
}